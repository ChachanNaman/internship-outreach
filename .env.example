# Copy this file to .env and fill in your real values.
# .env is gitignored -- never commit real credentials.

# Abstract API email validation key (free tier: 100 verifications/month, no card required)
# Get one at https://www.abstractapi.com/api/email-verification-validation-api
# -> Sign up -> Dashboard -> Email Validation -> API key (instant, self-serve)
ABSTRACT_API_KEY=your_abstract_api_key_here

# The Gmail address you are sending outreach emails from.
GMAIL_ADDRESS=you@gmail.com

# Gmail App Password (NOT your real Gmail password).
# Generate at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account first).
GMAIL_APP_PASSWORD=your_16_char_app_password_here
